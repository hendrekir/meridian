{
  "version": 2,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://web-production-b7653.up.railway.app/api/$1"
    },
    {
      "src": "/proxy/(.*)",
      "dest": "https://web-production-b7653.up.railway.app/proxy/$1"
    },
    {
